{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.{html,css,js,png,jpg,svg,ico,json}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "env": {
    "MONGODB_DB": "landscape-map",
    "SIGN_IN_COLLECTION": "sign in",
    "VERCEL": "1"
  }
}
